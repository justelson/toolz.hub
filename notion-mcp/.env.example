# Copy this file to .env and fill in your integration token.
# Create token at https://www.notion.so/profile/integrations
NOTION_TOKEN=ntn_your_integration_token_here

# Optional: override default API headers instead of NOTION_TOKEN.
# OPENAPI_MCP_HEADERS={"Authorization": "Bearer ntn_your_integration_token_here", "Notion-Version": "2025-09-03"}
